# Copie este arquivo para .env.oracle e preencha com os valores reais
# cp .env.oracle.example .env.oracle

# Credenciais Oracle
ORACLE_UID=seu_usuario_oracle
ORACLE_PWD=sua_senha_oracle
ORACLE_DBQ=nome_do_banco_ou_dsn

# Opcional: caminho para client libs Oracle
# ORACLE_CLIENT_LIB_DIR=C:/oracle/instantclient
# TNS_ADMIN=C:/oracle/network/admin
